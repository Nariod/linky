# Mistral Configuration for Linky C2 Framework
# Rust idiomatic coding guidelines · KISS/MVP approach
# Mis à jour 2026-03-25

[project]
name = "Linky C2 Framework"
philosophy = "KISS + MVP — solution la plus simple qui fonctionne"
language = "Rust 2021"
workspace_members = ["server", "links/windows", "links/linux", "links/osx", "links/common"]
reference = "TODO.txt pour le roadmap, CLAUDE.md pour les conventions"

# ── Architecture ─────────────────────────────────────────────────────────────

[architecture]
description = """
Workspace Cargo avec 5 crates :
  - server/     → binaire 'linky' (actix-web 4 + rustls 0.23 + CLI rustyline)
  - links/common/ → types wire partagés, client HTTP, crypto (AES-256-GCM)
  - links/linux/  → implant Linux (x86_64-unknown-linux-musl)
  - links/windows/ → implant Windows (x86_64-pc-windows-gnu)
"""

# ── Testing ─────────────────────────────────────────────────────────────────

[testing]
# Commandes automatiques pour les tests
auto_test_commands = [
    "cargo check",
    "cargo clippy",
    "cargo test",
    "cargo build --release",
    "podman build -t linky-c2 ."
]

# Fichiers clés pour les tests
key_test_files = [
    "server/src/links.rs",
    "server/src/tasks.rs", 
    "server/src/cli.rs",
    "server/src/routes.rs"
]

# Vérification de la fonctionnalité principale
test_command_output_display = """
Pour tester l'affichage des résultats de commandes:
1. Démarrer le serveur: cargo run --release --bin linky
2. Générer un implant: generate-linux 127.0.0.1:8443
3. Exécuter des commandes: whoami, pwd, etc.
4. Vérifier que les résultats s'affichent dans des boîtes formatées
"""

# ── Workflow ───────────────────────────────────────────────────────────────

[workflow]
# Étapes typiques de développement
typical_steps = [
    "Modifier le code dans server/src/",
    "Vérifier avec: cargo check",
    "Builder avec: cargo build --release",
    "Tester avec: cargo run --release --bin linky",
    "Builder podman: podman build -t linky-c2 .",
    "Nettoyer avec: cargo clean"
]

# Commandes Makefile disponibles
make_commands = [
    "make build - Construction en release",
    "make test - Tests unitaires", 
    "make check - Vérifications (check + clippy)",
    "make podman - Build podman",
    "make test-full - Tous les tests",
    "make clean - Nettoyage"
]

# ── Documentation ──────────────────────────────────────────────────────────

[documentation]
# Fichiers clés à comprendre
key_files = {
    "server/src/cli.rs": "Interface CLI principale et affichage des résultats",
    "server/src/routes.rs": "Gestion des requêtes HTTP et communication implant",
    "server/src/links.rs": "Gestion des liens/implants et système de tâches",
    "server/src/tasks.rs": "Définition des tâches et statuts",
    "Makefile": "Commandes rapides pour build et tests",
    "test_linky.sh": "Script de test automatisé complet"
}

# Problèmes courants et solutions
common_issues = {
    "Module path conflicts": "Utiliser crate:: au lieu des chemins relatifs",
    "Task completion not displaying": "Vérifier show_completed_task_results() dans cli.rs",
    "Implant communication issues": "Vérifier les logs dans routes.rs autour de complete_task()",
    "podman build problems": "Vérifier les permissions et le contexte de build"
}

# ── Conventions ─────────────────────────────────────────────────────────────

[conventions]
# Style de code
code_style = [
    "Utiliser rustfmt pour le formatage",
    "Limiter les lignes à 100 caractères",
    "Commentaires en français pour la documentation",
    "Noms de variables et fonctions en snake_case",
    "Types et traits en PascalCase"
]

# Gestion des erreurs
error_handling = [
    "Utiliser anyhow/thiserror pour les erreurs",
    "Ne pas paniquer dans le code de production",
    "Logger les erreurs avec tracing::error!",
    "Retourner Result<T, E> pour les fonctions publiques"
]

# Tests
testing = [
    "Écrire des tests unitaires pour les fonctions critiques",
    "Utiliser cargo test pour exécuter les tests",
    "Vérifier la couverture avec tarpaulin si disponible",
    "Tester les scénarios d'erreur"
]